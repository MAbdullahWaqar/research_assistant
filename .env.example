# Groq API key (required) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API key (required for Research Agent)
# Get yours at: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# Tavily transport: "sdk" (default, tavily-python) or "mcp" (remote Tavily MCP over HTTP)
# TAVILY_TRANSPORT=sdk

# Optional: full MCP URL (defaults to Tavily remote with TAVILY_API_KEY in query string)
# TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=your_tavily_api_key_here

# LangGraph checkpointing: "sqlite" (default, durable) or "memory" (ephemeral, tests)
# LANGGRAPH_CHECKPOINT_BACKEND=sqlite
# LANGGRAPH_SQLITE_PATH=.checkpoints/langgraph.sqlite

# Logging: INFO, DEBUG, WARNING, …  |  JSON_LOGS=1 for one-line JSON records
# LOG_LEVEL=INFO

# LangSmith (optional): set to trace LLM/tool spans in LangSmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=research-assistant
